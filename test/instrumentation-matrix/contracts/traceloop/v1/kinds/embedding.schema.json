{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "traceloop/v1/kinds/embedding.schema.json",
  "title": "Traceloop v1 — embedding span",
  "type": "object",
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "kind": { "type": "string" },
    "attributes": {
      "type": "object",
      "required": [
        "gen_ai.provider.name",
        "gen_ai.request.model",
        "gen_ai.operation.name"
      ],
      "properties": {
        "gen_ai.provider.name":      { "type": "string", "minLength": 1 },
        "gen_ai.request.model":      { "type": "string", "minLength": 1 },
        "gen_ai.operation.name":     { "type": "string", "minLength": 1 },
        "gen_ai.usage.input_tokens": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    }
  },
  "required": ["name", "kind", "attributes"]
}
