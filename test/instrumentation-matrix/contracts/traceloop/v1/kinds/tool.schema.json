{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "traceloop/v1/kinds/tool.schema.json",
  "title": "Traceloop v1 — tool span",
  "type": "object",
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "kind": { "type": "string" },
    "attributes": {
      "type": "object",
      "required": [],
      "properties": {
        "traceloop.entity.name":   { "type": "string" },
        "traceloop.entity.input":  { "type": "string" },
        "traceloop.entity.output": { "type": "string" },
        "traceloop.span.kind":     { "const": "tool" }
      },
      "additionalProperties": true
    }
  },
  "required": ["name", "kind", "attributes"]
}
