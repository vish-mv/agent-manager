{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "traceloop/v1/kinds/agent.schema.json",
  "title": "Traceloop v1 — agent span",
  "type": "object",
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "kind": { "type": "string" },
    "attributes": {
      "type": "object",
      "required": [],
      "properties": {
        "gen_ai.agent.name":   { "type": "string" },
        "gen_ai.provider.name":{ "type": "string" },
        "traceloop.span.kind": { "const": "agent" }
      },
      "additionalProperties": true
    }
  },
  "required": ["name", "kind", "attributes"]
}
